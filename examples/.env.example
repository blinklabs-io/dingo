# Local-development defaults for examples/docker-compose.yml.
# Copy to .env and change credentials before exposing the stack.

POSTGRES_DB=dingo_metadata
POSTGRES_USER=dingo
POSTGRES_PASSWORD=dingo
DINGO_GOV_LENS_PASSWORD=dingo_gov_lens

# Build Dingo from this checkout by default. To use a published image instead:
# DINGO_IMAGE=ghcr.io/blinklabs-io/dingo:<tag>

GOV_LENS_PORT=8088
BLOCKFROST_EXPLORER_PORT=5173
SUNDAE_PREVIEW_PORT=5174

DINGO_PLUGINS_API_BLOCKFROST_CONFIG_PORT=3000
DINGO_PLUGINS_API_UTXORPC_CONFIG_PORT=9090
DINGO_PLUGINS_API_MESH_CONFIG_PORT=8080
DINGO_METRICS_PORT=12798
DINGO_RELAY_PORT=3001

# Set this to 127.0.0.1 if Dingo API ports should be local-only.
DINGO_BIND_ADDR=0.0.0.0
